<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= appName %> Status</title>
  <style>
    :root {
      color-scheme: dark;
      --bg: #050505;
      --panel: rgba(255, 255, 255, 0.075);
      --panel-strong: rgba(255, 255, 255, 0.12);
      --text: #f5f7fb;
      --muted: #9ba4b5;
      --line: rgba(255, 255, 255, 0.16);
      --green: #2dfc8f;
      --cyan: #4dd8ff;
      --pink: #ff4fb8;
      --gold: #ffd166;
      --shadow: 0 24px 90px rgba(0, 0, 0, 0.48);
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      overflow-x: hidden;
      background:
        radial-gradient(circle at 15% 8%, rgba(77, 216, 255, 0.18), transparent 32rem),
        radial-gradient(circle at 82% 12%, rgba(255, 79, 184, 0.18), transparent 28rem),
        radial-gradient(circle at 52% 86%, rgba(45, 252, 143, 0.12), transparent 30rem),
        linear-gradient(145deg, #020202, #0b0d12 48%, #030304);
      color: var(--text);
    }

    button,
    a {
      font: inherit;
    }

    .stage {
      position: relative;
      min-height: 100vh;
      padding: 28px;
      isolation: isolate;
    }

    canvas {
      position: fixed;
      inset: 0;
      z-index: -2;
      width: 100%;
      height: 100%;
    }

    .mesh {
      position: fixed;
      inset: 0;
      z-index: -1;
      background-image:
        linear-gradient(rgba(255, 255, 255, 0.055) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255, 255, 255, 0.055) 1px, transparent 1px);
      background-size: 72px 72px;
      mask-image: radial-gradient(circle at center, black, transparent 72%);
      opacity: 0.42;
    }

    .shell {
      width: min(1180px, 100%);
      margin: 0 auto;
      min-height: calc(100vh - 56px);
      display: grid;
      grid-template-rows: auto 1fr auto;
      gap: 22px;
    }

    .topbar,
    .glass,
    .tile,
    .endpoint {
      border: 1px solid var(--line);
      background: linear-gradient(135deg, rgba(255, 255, 255, 0.11), rgba(255, 255, 255, 0.045));
      box-shadow: var(--shadow);
      backdrop-filter: blur(24px);
    }

    .topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 14px 16px;
      border-radius: 8px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
      min-width: 0;
    }

    .mark {
      width: 42px;
      height: 42px;
      display: grid;
      place-items: center;
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 8px;
      background: conic-gradient(from 120deg, var(--cyan), var(--pink), var(--green), var(--cyan));
      color: #050505;
      font-weight: 900;
      font-size: 24px;
      line-height: 1;
    }

    .brand h1 {
      margin: 0;
      font-size: clamp(18px, 3vw, 26px);
      line-height: 1;
      letter-spacing: 0;
    }

    .brand p,
    .footer,
    .muted {
      color: var(--muted);
    }

    .brand p {
      margin: 5px 0 0;
      font-size: 13px;
    }

    .pulse {
      display: inline-flex;
      align-items: center;
      gap: 9px;
      min-height: 38px;
      padding: 8px 12px;
      border-radius: 999px;
      border: 1px solid rgba(45, 252, 143, 0.28);
      background: rgba(45, 252, 143, 0.09);
      color: #c8ffe0;
      white-space: nowrap;
    }

    .pulse::before {
      content: "";
      width: 9px;
      height: 9px;
      border-radius: 50%;
      background: var(--green);
      box-shadow: 0 0 0 0 rgba(45, 252, 143, 0.65);
      animation: breathe 1.8s infinite;
    }

    .hero {
      display: grid;
      grid-template-columns: minmax(0, 1.02fr) minmax(320px, 0.98fr);
      align-items: stretch;
      gap: 22px;
    }

    .glass {
      border-radius: 8px;
      padding: clamp(22px, 5vw, 46px);
      position: relative;
      overflow: hidden;
    }

    .glass::after {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: linear-gradient(115deg, transparent 0 36%, rgba(255, 255, 255, 0.16) 46%, transparent 56% 100%);
      transform: translateX(-120%);
      animation: scan 7s ease-in-out infinite;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 20px;
      color: var(--cyan);
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
    }

    .hero h2 {
      margin: 0;
      max-width: 720px;
      font-size: clamp(42px, 8vw, 92px);
      line-height: 0.92;
      letter-spacing: 0;
    }

    .hero h2 span {
      background: linear-gradient(90deg, #ffffff, var(--cyan), var(--green), #ffffff);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      background-size: 230% 100%;
      animation: glowText 6s linear infinite;
    }

    .hero-copy {
      max-width: 600px;
      margin: 22px 0 0;
      color: #c7cfde;
      font-size: clamp(16px, 2vw, 20px);
      line-height: 1.6;
    }

    .actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 30px;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      min-height: 46px;
      padding: 0 16px;
      border-radius: 8px;
      border: 1px solid rgba(255, 255, 255, 0.18);
      background: rgba(255, 255, 255, 0.09);
      color: var(--text);
      text-decoration: none;
      cursor: pointer;
      transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
    }

    .btn:hover,
    .btn:focus-visible {
      transform: translateY(-2px);
      border-color: rgba(77, 216, 255, 0.7);
      background: rgba(77, 216, 255, 0.13);
      outline: none;
    }

    .btn.primary {
      background: linear-gradient(135deg, var(--text), #b9fff0);
      color: #050505;
      border-color: transparent;
      font-weight: 800;
    }

    .orbital {
      min-height: 560px;
      display: grid;
      place-items: center;
    }

    .core {
      position: relative;
      width: min(420px, 82vw);
      aspect-ratio: 1;
      transform-style: preserve-3d;
      transition: transform 160ms ease;
    }

    .ring {
      position: absolute;
      inset: 12%;
      border: 1px solid rgba(255, 255, 255, 0.18);
      border-radius: 50%;
      animation: rotate 14s linear infinite;
    }

    .ring:nth-child(2) {
      inset: 5%;
      transform: rotateX(68deg);
      border-color: rgba(77, 216, 255, 0.42);
      animation-duration: 18s;
    }

    .ring:nth-child(3) {
      inset: 20%;
      transform: rotateY(64deg);
      border-color: rgba(255, 79, 184, 0.42);
      animation-duration: 11s;
      animation-direction: reverse;
    }

    .x-core {
      position: absolute;
      inset: 25%;
      display: grid;
      place-items: center;
      border-radius: 50%;
      border: 1px solid rgba(255, 255, 255, 0.22);
      background:
        radial-gradient(circle at 34% 28%, rgba(255, 255, 255, 0.34), transparent 26%),
        linear-gradient(145deg, rgba(255, 255, 255, 0.16), rgba(255, 255, 255, 0.035));
      box-shadow:
        0 0 70px rgba(77, 216, 255, 0.28),
        inset 0 0 80px rgba(255, 255, 255, 0.1);
      font-size: clamp(86px, 14vw, 138px);
      font-weight: 950;
      color: #ffffff;
    }

    .satellite {
      position: absolute;
      width: 72px;
      min-height: 72px;
      display: grid;
      place-items: center;
      padding: 8px;
      border-radius: 8px;
      border: 1px solid rgba(255, 255, 255, 0.2);
      background: rgba(0, 0, 0, 0.48);
      color: #ffffff;
      text-align: center;
      font-size: 12px;
      font-weight: 800;
      box-shadow: 0 18px 50px rgba(0, 0, 0, 0.34);
    }

    .satellite.one {
      top: 3%;
      left: 38%;
    }

    .satellite.two {
      right: 1%;
      top: 46%;
    }

    .satellite.three {
      left: 4%;
      bottom: 14%;
    }

    .status-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 14px;
    }

    .tile,
    .endpoint {
      border-radius: 8px;
    }

    .tile {
      padding: 18px;
      min-height: 126px;
    }

    .tile .label {
      color: var(--muted);
      font-size: 12px;
      text-transform: uppercase;
      font-weight: 800;
    }

    .tile strong {
      display: block;
      margin-top: 18px;
      font-size: clamp(20px, 4vw, 34px);
      line-height: 1;
      overflow-wrap: anywhere;
    }

    .tile small {
      display: block;
      margin-top: 8px;
      color: #c6ccda;
    }

    .endpoints {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 14px;
    }

    .endpoint {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      min-height: 76px;
      padding: 16px;
      color: inherit;
      text-decoration: none;
      transition: transform 160ms ease, border-color 160ms ease, background 160ms ease;
    }

    .endpoint:hover,
    .endpoint:focus-visible {
      transform: translateY(-3px);
      border-color: rgba(255, 255, 255, 0.42);
      background: var(--panel-strong);
      outline: none;
    }

    .endpoint span {
      color: var(--muted);
      font-size: 13px;
    }

    .endpoint code {
      display: block;
      margin-top: 5px;
      color: #ffffff;
      font-size: 14px;
      overflow-wrap: anywhere;
    }

    .terminal {
      margin-top: 24px;
      padding: 16px;
      border: 1px solid rgba(255, 255, 255, 0.13);
      border-radius: 8px;
      background: rgba(0, 0, 0, 0.36);
      font-family: "Cascadia Code", Consolas, monospace;
      color: #d9ffe9;
      min-height: 118px;
      overflow: hidden;
    }

    .terminal-line {
      margin: 0 0 8px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .footer {
      display: flex;
      justify-content: space-between;
      gap: 16px;
      padding-bottom: 4px;
      font-size: 13px;
    }

    @keyframes breathe {
      70% {
        box-shadow: 0 0 0 12px rgba(45, 252, 143, 0);
      }
      100% {
        box-shadow: 0 0 0 0 rgba(45, 252, 143, 0);
      }
    }

    @keyframes scan {
      0%, 48% {
        transform: translateX(-120%);
      }
      62%, 100% {
        transform: translateX(120%);
      }
    }

    @keyframes glowText {
      to {
        background-position: 230% 0;
      }
    }

    @keyframes rotate {
      to {
        transform: rotate(360deg);
      }
    }

    @media (max-width: 920px) {
      .stage {
        padding: 18px;
      }

      .hero,
      .status-grid,
      .endpoints {
        grid-template-columns: 1fr;
      }

      .orbital {
        min-height: 420px;
      }
    }

    @media (max-width: 620px) {
      .topbar,
      .footer {
        align-items: flex-start;
        flex-direction: column;
      }

      .pulse {
        width: 100%;
        justify-content: center;
      }

      .satellite {
        width: 64px;
        min-height: 64px;
        font-size: 11px;
      }
    }
  </style>
</head>
<body>
  <canvas id="constellation" aria-hidden="true"></canvas>
  <div class="mesh" aria-hidden="true"></div>

  <main class="stage">
    <div class="shell">
      <header class="topbar">
        <div class="brand">
          <div class="mark">X</div>
          <div>
            <h1><%= appName %></h1>
            <p>Express, MongoDB, uploads, auth, and posts are awake.</p>
          </div>
        </div>
        <div class="pulse"><%= status %> on port <%= port %></div>
      </header>

      <section class="hero">
        <article class="glass">
          <div class="eyebrow">Live backend signal</div>
          <h2><span><%= message %></span></h2>
          <p class="hero-copy">
            This is no longer a plain health-check line. It is a living command deck for the API:
            responsive, animated, status-aware, and ready to make the first visit feel intentional.
          </p>

          <div class="actions">
            <a class="btn primary" href="/api/posts">Open posts API</a>
            <a class="btn" href="/api/auth/me">Auth probe</a>
            <button class="btn" id="sparkButton" type="button">Ignite signal</button>
          </div>

          <div class="terminal" aria-live="polite" id="terminal">
            <p class="terminal-line">server.boot: status=<%= status %></p>
            <p class="terminal-line">database.link: <%= database %></p>
            <p class="terminal-line">mongo.uri: <%= mongoConfigured ? "configured" : "missing" %></p>
            <p class="terminal-line">render.time: <%= generatedAt %></p>
          </div>
        </article>

        <aside class="glass orbital" aria-label="Animated API core">
          <div class="core" id="core">
            <div class="ring"></div>
            <div class="ring"></div>
            <div class="ring"></div>
            <div class="x-core">X</div>
            <div class="satellite one">AUTH</div>
            <div class="satellite two">POSTS</div>
            <div class="satellite three">MEDIA</div>
          </div>
        </aside>
      </section>

      <section class="status-grid" aria-label="Backend status">
        <div class="tile">
          <span class="label">Server</span>
          <strong><%= status %></strong>
          <small>HTTP root is rendering EJS</small>
        </div>
        <div class="tile">
          <span class="label">Database</span>
          <strong><%= database %></strong>
          <small>Mongoose connection state</small>
        </div>
        <div class="tile">
          <span class="label">Mongo URI</span>
          <strong><%= mongoConfigured ? "Ready" : "Missing" %></strong>
          <small>Environment configuration</small>
        </div>
        <div class="tile">
          <span class="label">Runtime</span>
          <strong id="uptime">00:00</strong>
          <small>Time since page opened</small>
        </div>
      </section>

      <section class="endpoints" aria-label="API endpoints">
        <a class="endpoint" href="/api/auth/me">
          <div>
            <span>Identity</span>
            <code>/api/auth</code>
          </div>
          <strong>01</strong>
        </a>
        <a class="endpoint" href="/api/posts">
          <div>
            <span>Timeline</span>
            <code>/api/posts</code>
          </div>
          <strong>02</strong>
        </a>
        <a class="endpoint" href="/api/upload">
          <div>
            <span>Media</span>
            <code>/api/upload</code>
          </div>
          <strong>03</strong>
        </a>
      </section>

      <footer class="footer">
        <span>Generated at <%= generatedAt %></span>
        <span>Move your pointer across the core.</span>
      </footer>
    </div>
  </main>

  <script>
    const data = <%- JSON.stringify({ status, database, mongoConfigured, generatedAt }) %>;
    const canvas = document.getElementById("constellation");
    const ctx = canvas.getContext("2d");
    const core = document.getElementById("core");
    const terminal = document.getElementById("terminal");
    const uptime = document.getElementById("uptime");
    const sparkButton = document.getElementById("sparkButton");
    const particles = [];
    let start = Date.now();
    let pointer = { x: 0.5, y: 0.5, active: false };

    function resize() {
      const ratio = window.devicePixelRatio || 1;
      canvas.width = Math.floor(window.innerWidth * ratio);
      canvas.height = Math.floor(window.innerHeight * ratio);
      canvas.style.width = window.innerWidth + "px";
      canvas.style.height = window.innerHeight + "px";
      ctx.setTransform(ratio, 0, 0, ratio, 0, 0);
      seedParticles();
    }

    function seedParticles() {
      particles.length = 0;
      const count = Math.min(110, Math.floor((window.innerWidth * window.innerHeight) / 11000));
      for (let i = 0; i < count; i += 1) {
        particles.push({
          x: Math.random() * window.innerWidth,
          y: Math.random() * window.innerHeight,
          vx: (Math.random() - 0.5) * 0.35,
          vy: (Math.random() - 0.5) * 0.35,
          r: Math.random() * 1.8 + 0.6,
          hue: [164, 193, 320, 44][Math.floor(Math.random() * 4)]
        });
      }
    }

    function draw() {
      ctx.clearRect(0, 0, window.innerWidth, window.innerHeight);
      particles.forEach((p, index) => {
        const pullX = (pointer.x * window.innerWidth - p.x) * (pointer.active ? 0.0008 : 0.0002);
        const pullY = (pointer.y * window.innerHeight - p.y) * (pointer.active ? 0.0008 : 0.0002);
        p.vx += pullX;
        p.vy += pullY;
        p.vx *= 0.985;
        p.vy *= 0.985;
        p.x += p.vx;
        p.y += p.vy;

        if (p.x < -20) p.x = window.innerWidth + 20;
        if (p.x > window.innerWidth + 20) p.x = -20;
        if (p.y < -20) p.y = window.innerHeight + 20;
        if (p.y > window.innerHeight + 20) p.y = -20;

        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = "hsla(" + p.hue + ", 100%, 70%, 0.72)";
        ctx.fill();

        for (let j = index + 1; j < particles.length; j += 1) {
          const other = particles[j];
          const dx = p.x - other.x;
          const dy = p.y - other.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 120) {
            ctx.strokeStyle = "rgba(255,255,255," + (0.11 - dist / 1400) + ")";
            ctx.lineWidth = 1;
            ctx.beginPath();
            ctx.moveTo(p.x, p.y);
            ctx.lineTo(other.x, other.y);
            ctx.stroke();
          }
        }
      });
      requestAnimationFrame(draw);
    }

    function addLog(text) {
      const line = document.createElement("p");
      line.className = "terminal-line";
      line.textContent = text;
      terminal.appendChild(line);
      while (terminal.children.length > 5) terminal.removeChild(terminal.firstElementChild);
    }

    function updateUptime() {
      const seconds = Math.floor((Date.now() - start) / 1000);
      const mins = String(Math.floor(seconds / 60)).padStart(2, "0");
      const secs = String(seconds % 60).padStart(2, "0");
      uptime.textContent = mins + ":" + secs;
    }

    window.addEventListener("resize", resize);
    window.addEventListener("pointermove", (event) => {
      pointer = {
        x: event.clientX / window.innerWidth,
        y: event.clientY / window.innerHeight,
        active: true
      };
      const rotateY = (pointer.x - 0.5) * 18;
      const rotateX = (0.5 - pointer.y) * 18;
      core.style.transform = "rotateX(" + rotateX + "deg) rotateY(" + rotateY + "deg)";
    });
    window.addEventListener("pointerleave", () => {
      pointer.active = false;
      core.style.transform = "rotateX(0deg) rotateY(0deg)";
    });

    sparkButton.addEventListener("click", () => {
      pointer.active = true;
      addLog("signal.ignite: particles synchronized with " + data.status + " backend");
      particles.forEach((p) => {
        p.vx += (Math.random() - 0.5) * 5;
        p.vy += (Math.random() - 0.5) * 5;
      });
    });

    resize();
    draw();
    updateUptime();
    setInterval(updateUptime, 1000);
    setInterval(() => addLog("heartbeat: " + new Date().toLocaleTimeString() + " db=" + data.database), 5000);
  </script>
</body>
</html>
