<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Server of X by Veer</title>
  <style>
    :root {
      color-scheme: dark;
      --bg: #000;
      --ink: #f7f9f9;
      --muted: #a9b2bc;
      --dim: #66717d;
      --line: rgba(255, 255, 255, 0.14);
      --line-bright: rgba(255, 255, 255, 0.34);
      --card: #0b0d10;
      --card-2: #111419;
      --blue: #1d9bf0;
      --blue-soft: rgba(29, 155, 240, 0.34);
      --shadow: 0 30px 90px rgba(0, 0, 0, 0.68);
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    * {
      box-sizing: border-box;
    }

    html {
      background: var(--bg);
    }

    body {
      margin: 0;
      min-height: 100vh;
      background:
        radial-gradient(circle at 50% 20%, rgba(29, 155, 240, 0.16), transparent 28rem),
        radial-gradient(circle at 50% 76%, rgba(255, 255, 255, 0.09), transparent 30rem),
        linear-gradient(#020305, #000 58%);
      color: var(--ink);
      overflow-x: hidden;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background-image:
        radial-gradient(circle, rgba(255, 255, 255, 0.56) 0 1px, transparent 1.5px),
        radial-gradient(circle, rgba(255, 255, 255, 0.28) 0 1px, transparent 1.5px);
      background-position: 20px 18px, 86px 92px;
      background-size: 170px 170px, 240px 240px;
      opacity: 0.22;
      mask-image: linear-gradient(to bottom, black 0 70%, transparent 100%);
    }

    .page {
      position: relative;
    }

    .section {
      width: min(1160px, calc(100% - 44px));
      margin: 0 auto;
    }

    .hero {
      min-height: 96svh;
      display: grid;
      grid-template-rows: auto 1fr auto;
      padding: 30px 0 28px;
    }

    .nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      min-height: 66px;
      padding: 12px 14px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: rgba(3, 4, 6, 0.76);
      box-shadow: var(--shadow);
      backdrop-filter: blur(22px);
    }

    .brand {
      display: flex;
      align-items: center;
      min-width: 0;
      gap: 12px;
    }

    .x-mark {
      width: 40px;
      height: 40px;
      display: grid;
      place-items: center;
      border-radius: 8px;
      background: var(--ink);
      color: #000;
      font-size: 24px;
      font-weight: 950;
      line-height: 1;
    }

    .brand strong {
      display: block;
      line-height: 1.1;
    }

    .brand span {
      display: block;
      margin-top: 4px;
      color: var(--dim);
      font-size: 12px;
    }

    .pill {
      display: inline-flex;
      align-items: center;
      gap: 9px;
      min-height: 36px;
      padding: 0 12px;
      border: 1px solid var(--line);
      border-radius: 999px;
      color: var(--muted);
      font-size: 13px;
      white-space: nowrap;
    }

    .pill::before {
      content: "";
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--blue);
      box-shadow: 0 0 18px rgba(29, 155, 240, 0.8);
    }

    .hero-scene {
      position: relative;
      min-height: 610px;
      display: grid;
      place-items: center;
      text-align: center;
      isolation: isolate;
    }

    .hero-scene::before {
      content: "X";
      position: absolute;
      z-index: -2;
      color: rgba(255, 255, 255, 0.035);
      font-size: min(54vw, 620px);
      font-weight: 950;
      line-height: 1;
      transform: translateY(24px);
    }

    .horizon {
      position: absolute;
      left: 50%;
      bottom: 18%;
      width: min(86vw, 940px);
      height: 1px;
      transform: translateX(-50%);
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.76), transparent);
      box-shadow:
        0 0 32px rgba(29, 155, 240, 0.54),
        0 0 120px rgba(255, 255, 255, 0.2);
      opacity: 0.58;
    }

    .horizon::after {
      content: "";
      position: absolute;
      left: 50%;
      bottom: -98px;
      width: min(70vw, 680px);
      height: 190px;
      transform: translateX(-50%);
      background: radial-gradient(ellipse, rgba(255, 255, 255, 0.32), rgba(29, 155, 240, 0.22) 38%, transparent 70%);
      filter: blur(22px);
      opacity: 0.52;
    }

    .hero-copy {
      width: min(900px, 100%);
      padding-bottom: 84px;
    }

    .eyebrow {
      margin: 0 0 22px;
      color: var(--muted);
      font-size: 13px;
      font-weight: 750;
      letter-spacing: 0;
      text-transform: uppercase;
    }

    h1 {
      margin: 0;
      font-size: clamp(62px, 12.5vw, 164px);
      line-height: 0.86;
      font-weight: 860;
      letter-spacing: 0;
      background: linear-gradient(180deg, #fff 2%, #c8ced4 34%, #565f69 62%, #171a1e 90%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      text-shadow: 0 36px 42px rgba(0, 0, 0, 0.8);
    }

    .subline {
      width: min(620px, 100%);
      margin: 26px auto 0;
      color: var(--muted);
      font-size: clamp(15px, 1.8vw, 18px);
      line-height: 1.68;
    }

    .hero-facts {
      display: flex;
      justify-content: center;
      flex-wrap: wrap;
      gap: 10px;
      margin-top: 26px;
    }

    .chip {
      padding: 9px 12px;
      border: 1px solid var(--line);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.035);
      color: var(--muted);
      font-size: 13px;
    }

    .scroll-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      color: var(--dim);
      font-size: 13px;
    }

    .scroll-row strong {
      color: var(--muted);
      font-weight: 600;
    }

    .dashboard {
      min-height: 96svh;
      padding: 54px 0 76px;
    }

    .dashboard-head {
      display: grid;
      grid-template-columns: 1fr minmax(260px, 390px);
      align-items: end;
      gap: 28px;
      margin-bottom: 18px;
    }

    .dashboard-head h2 {
      margin: 0;
      font-size: clamp(36px, 7vw, 88px);
      line-height: 0.9;
      letter-spacing: 0;
    }

    .dashboard-head p {
      margin: 0;
      color: var(--muted);
      line-height: 1.55;
    }

    .mosaic-frame {
      padding: 12px;
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 8px;
      background: #020202;
      box-shadow: var(--shadow);
    }

    .mosaic {
      --mx: 50%;
      --my: 50%;
      display: grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      grid-template-rows: 160px 148px 148px 122px;
      gap: 12px;
      grid-template-areas:
        "server server server server server database database database mongo mongo runtime runtime"
        "server server server server server routes routes routes routes renderer renderer renderer"
        "signal signal signal stack stack routes routes routes routes generated generated generated"
        "signal signal signal stack stack health health health health generated generated generated";
    }

    .tile {
      position: relative;
      min-width: 0;
      overflow: hidden;
      border: 1px solid var(--line);
      border-radius: 8px;
      background:
        radial-gradient(circle at 20% 0%, rgba(255, 255, 255, 0.08), transparent 26rem),
        linear-gradient(145deg, rgba(255, 255, 255, 0.075), rgba(255, 255, 255, 0.025)),
        var(--card);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05);
    }

    .tile::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: radial-gradient(circle 230px at var(--mx) var(--my), rgba(255, 255, 255, 0.16), transparent 58%);
      opacity: 0;
      transition: opacity 160ms ease;
    }

    .tile::after {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      border-radius: inherit;
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0);
      background: radial-gradient(circle 180px at var(--mx) var(--my), var(--blue-soft), transparent 62%);
      opacity: 0;
      transition: opacity 160ms ease;
    }

    .tile:hover::before,
    .tile:hover::after {
      opacity: 1;
    }

    .tile-inner {
      position: relative;
      z-index: 1;
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 18px;
    }

    .server { grid-area: server; }
    .database { grid-area: database; }
    .mongo { grid-area: mongo; }
    .runtime { grid-area: runtime; }
    .routes { grid-area: routes; }
    .renderer { grid-area: renderer; }
    .signal { grid-area: signal; }
    .stack { grid-area: stack; }
    .health { grid-area: health; }
    .generated { grid-area: generated; }

    .label {
      color: var(--dim);
      font-size: 11px;
      font-weight: 820;
      text-transform: uppercase;
    }

    .value {
      margin: 10px 0 0;
      color: var(--ink);
      font-size: clamp(24px, 3vw, 44px);
      font-weight: 830;
      line-height: 0.98;
      letter-spacing: 0;
      overflow-wrap: anywhere;
    }

    .server .value {
      max-width: 390px;
      font-size: clamp(46px, 6.6vw, 84px);
    }

    .tiny .value {
      font-size: clamp(21px, 2vw, 30px);
    }

    .tile p {
      margin: 14px 0 0;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.55;
    }

    .mini-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
      margin-top: 18px;
    }

    .mini-box,
    .route-box,
    .stack-item {
      border: 1px solid var(--line);
      border-radius: 8px;
      background: rgba(255, 255, 255, 0.035);
      color: var(--muted);
      font-size: 12px;
    }

    .mini-box {
      padding: 11px;
    }

    .mini-box strong {
      display: block;
      color: var(--ink);
      font-size: 15px;
      line-height: 1.15;
      overflow-wrap: anywhere;
    }

    .route-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      margin-top: 18px;
    }

    .route-box,
    .stack-item {
      padding: 11px;
      overflow-wrap: anywhere;
    }

    .route-box strong,
    .stack-item strong {
      display: block;
      margin-bottom: 6px;
      color: var(--ink);
      font-size: 13px;
    }

    .stack-list {
      display: grid;
      gap: 8px;
      margin-top: 16px;
    }

    .signal-line {
      height: 76px;
      margin-top: 18px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background:
        linear-gradient(90deg, transparent 0 12%, rgba(255, 255, 255, 0.2) 22%, transparent 34% 100%),
        repeating-linear-gradient(90deg, rgba(255, 255, 255, 0.08) 0 1px, transparent 1px 18px);
      opacity: 0.75;
    }

    .generated code {
      display: block;
      margin-top: 16px;
      color: var(--muted);
      font-family: "Cascadia Code", Consolas, monospace;
      font-size: 12px;
      line-height: 1.45;
      overflow-wrap: anywhere;
    }

    @media (max-width: 1050px) {
      .mosaic {
        grid-template-columns: repeat(8, minmax(0, 1fr));
        grid-template-rows: 170px 150px 150px 150px 122px;
        grid-template-areas:
          "server server server server database database mongo mongo"
          "server server server server routes routes routes routes"
          "signal signal stack stack routes routes routes routes"
          "renderer renderer health health generated generated generated generated"
          "runtime runtime runtime runtime generated generated generated generated";
      }
    }

    @media (max-width: 760px) {
      .section {
        width: min(100% - 28px, 640px);
      }

      .hero {
        min-height: 92svh;
        padding-top: 16px;
      }

      .nav,
      .scroll-row,
      .dashboard-head {
        align-items: flex-start;
        grid-template-columns: 1fr;
        flex-direction: column;
      }

      .pill {
        width: 100%;
        justify-content: center;
      }

      .hero-scene {
        min-height: 560px;
      }

      .mosaic {
        grid-template-columns: 1fr;
        grid-template-rows: none;
        grid-template-areas:
          "server"
          "database"
          "mongo"
          "runtime"
          "routes"
          "renderer"
          "signal"
          "stack"
          "health"
          "generated";
      }

      .tile {
        min-height: 138px;
      }

      .server {
        min-height: 280px;
      }

      .route-grid,
      .mini-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body
  data-status="<%= status %>"
  data-app-name="<%= appName %>"
  data-message="<%= message %>"
  data-database="<%= database %>"
  data-mongo-state="<%= mongoConfigured ? 'Ready' : 'Missing' %>"
  data-port="<%= port %>"
  data-generated="<%= generatedAt %>"
>
  <main class="page">
    <section class="section hero" aria-label="Server landing">
      <nav class="nav">
        <div class="brand">
          <div class="x-mark">
            <svg viewBox="0 0 24 24" aria-hidden="true" style="width: 22px; height: 22px; fill: #000;">
              <path d="M21.742 21.75l-7.563-11.179 7.056-8.321h-2.456l-5.691 6.714-4.54-6.714H2.359l7.29 10.776L2.25 21.75h2.456l6.035-7.118 4.818 7.118h6.191-.008zM7.739 3.818L18.81 20.182h-2.447L5.29 3.818h2.447z"></path>
            </svg>
          </div>
          <div>
            <strong>Server of X</strong>
            <span>Backend by Veer</span>
          </div>
        </div>
        <div class="pill"><span data-bind="status">OK</span> on port <span data-bind="port">5000</span></div>
      </nav>

      <div class="hero-scene">
        <div class="horizon" aria-hidden="true"></div>
        <div class="hero-copy">
          <p class="eyebrow">Live backend instance</p>
          <h1>Server of X<br />by Veer</h1>
          <p class="subline">
            <span data-bind="message">Backend server is running smoothly</span>. A clean status scene rendered by Express and EJS.
          </p>
          <div class="hero-facts" aria-label="Quick server facts">
            <span class="chip">Express</span>
            <span class="chip">EJS rendered</span>
            <span class="chip">MongoDB: <span data-bind="database">Checking</span></span>
          </div>
        </div>
      </div>

      <div class="scroll-row">
        <span>Generated <strong data-bind="generated">when the server rendered this page</strong></span>
        <strong>Scroll for system state</strong>
      </div>
    </section>

    <section class="section dashboard" id="dashboard" aria-label="Backend status dashboard">
      <div class="dashboard-head">
        <h2>System<br />state</h2>
        <p>One assembled dashboard, like puzzle blocks: every card locks into the same frame and keeps the X theme.</p>
      </div>

      <div class="mosaic-frame">
        <div class="mosaic" id="mosaic">
          <article class="tile server">
            <div class="tile-inner">
              <div>
                <span class="label">Server</span>
                <div class="value" data-bind="status">OK</div>
                <p><span data-bind="message">Backend server is running smoothly</span>. The root route is rendering this EJS page from Express.</p>
              </div>
              <div class="mini-grid">
                <div class="mini-box">
                  <strong data-bind="port">5000</strong>
                  Port
                </div>
                <div class="mini-box">
                  <strong id="uptime">00:00</strong>
                  Page runtime
                </div>
              </div>
            </div>
          </article>

          <article class="tile database tiny">
            <div class="tile-inner">
              <div>
                <span class="label">Database</span>
                <div class="value" data-bind="database">Checking</div>
                <p>Mongoose connection state from the live backend process.</p>
              </div>
            </div>
          </article>

          <article class="tile mongo tiny">
            <div class="tile-inner">
              <div>
                <span class="label">Mongo URI</span>
                <div class="value" data-bind="mongoState">Ready</div>
                <p>Environment variable check.</p>
              </div>
            </div>
          </article>

          <article class="tile runtime tiny">
            <div class="tile-inner">
              <div>
                <span class="label">Runtime</span>
                <div class="value" id="runtimeLarge">00:00</div>
                <p>Time since this page opened.</p>
              </div>
            </div>
          </article>

          <article class="tile routes">
            <div class="tile-inner">
              <div>
                <span class="label">API namespaces</span>
                <div class="value">3 active</div>
                <p>Shown as labels only, so they do not open protected JSON/error pages.</p>
                <div class="route-grid">
                  <div class="route-box">
                    <strong>Identity</strong>
                    /api/auth
                  </div>
                  <div class="route-box">
                    <strong>Timeline</strong>
                    /api/posts
                  </div>
                  <div class="route-box">
                    <strong>Media</strong>
                    /api/upload
                  </div>
                </div>
              </div>
            </div>
          </article>

          <article class="tile renderer tiny">
            <div class="tile-inner">
              <div>
                <span class="label">Renderer</span>
                <div class="value">EJS</div>
                <p>HTML is prepared on the server.</p>
              </div>
            </div>
          </article>

          <article class="tile signal">
            <div class="tile-inner">
              <div>
                <span class="label">Signal</span>
                <div class="value">Live</div>
                <p>Subtle static scene, no noisy animation.</p>
                <div class="signal-line" aria-hidden="true"></div>
              </div>
            </div>
          </article>

          <article class="tile stack">
            <div class="tile-inner">
              <div>
                <span class="label">Stack</span>
                <div class="value">API</div>
                <div class="stack-list">
                  <div class="stack-item">
                    <strong>Express</strong>
                    routing layer
                  </div>
                  <div class="stack-item">
                    <strong>MongoDB</strong>
                    data layer
                  </div>
                </div>
              </div>
            </div>
          </article>

          <article class="tile health">
            <div class="tile-inner">
              <div>
                <span class="label">Health check</span>
                <div class="value">HTML</div>
                <p>This route now returns a designed page instead of plain JSON.</p>
              </div>
            </div>
          </article>

          <article class="tile generated">
            <div class="tile-inner">
              <div>
                <span class="label">Generated at</span>
                <div class="value">Stamp</div>
                <p>This timestamp is passed from Express into the EJS template on every request.</p>
                <code data-bind="generated">waiting for server data</code>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>
  </main>

  <script>
    const source = document.body.dataset;
    const fields = {
      status: readValue(source.status, "OK"),
      appName: readValue(source.appName, "X Clone API"),
      message: readValue(source.message, "Backend server is running smoothly"),
      database: readValue(source.database, "Checking"),
      mongoState: readValue(source.mongoState, "Ready"),
      port: readValue(source.port, "5000"),
      generated: readValue(source.generated, "preview mode")
    };
    const startedAt = Date.now();
    const mosaic = document.getElementById("mosaic");
    const uptime = document.getElementById("uptime");
    const runtimeLarge = document.getElementById("runtimeLarge");

    function readValue(value, fallback) {
      if (!value || value.includes("<%") || value.includes("%>")) return fallback;
      return value;
    }

    document.querySelectorAll("[data-bind]").forEach((node) => {
      const key = node.dataset.bind;
      if (fields[key]) node.textContent = fields[key];
    });

    function moveGlow(event) {
      document.querySelectorAll(".tile").forEach((tile) => {
        const rect = tile.getBoundingClientRect();
        tile.style.setProperty("--mx", event.clientX - rect.left + "px");
        tile.style.setProperty("--my", event.clientY - rect.top + "px");
      });
    }

    function updateRuntime() {
      const total = Math.floor((Date.now() - startedAt) / 1000);
      const minutes = String(Math.floor(total / 60)).padStart(2, "0");
      const seconds = String(total % 60).padStart(2, "0");
      const value = minutes + ":" + seconds;
      uptime.textContent = value;
      runtimeLarge.textContent = value;
    }

    mosaic.addEventListener("pointermove", moveGlow);
    updateRuntime();
    setInterval(updateRuntime, 1000);
  </script>
</body>
</html>
